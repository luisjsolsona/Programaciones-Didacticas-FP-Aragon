# =============================================================
# .gitignore — Ficheros a excluir del repositorio
# =============================================================

# Base de datos SQLite (datos reales, no van al repo)
data/
!data/.gitkeep

# Dependencias Node.js (se instalan con npm install en el build)
backend/node_modules/

# Variables de entorno locales (si usas .env en desarrollo)
.env
.env.local

# Logs
*.log
npm-debug.log*

# macOS
.DS_Store
